<idea-plugin visibility="public">
  <dependencies>
    <module name="perl5.plugin.common.main"/>
    <module name="perl5.plugin.backend.main"/>
    <module name="intellij.platform.structureView.impl"/>
  </dependencies>

  <extensions defaultExtensionNs="com.intellij">
    <lang.psiStructureViewFactory language="Perl5"
                                  implementationClass="com.perl5.lang.perl.idea.structureView.PerlStructureViewFactory"/>
    <lang.psiStructureViewFactory language="Perl5 POD" implementationClass="com.perl5.lang.pod.idea.structureView.PodStructureViewFactory"/>
  </extensions>
</idea-plugin>